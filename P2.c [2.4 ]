#include <stdio.h>
#include <string.h>

int main() {
    int choice, i, len;
    char str[100], ch;

    do {
        printf("\n--- STRING MENU ---\n");
        printf("1. Reverse a String\n");
        printf("2. Convert to Uppercase\n");
        printf("3. Convert to Lowercase\n");
        printf("4. Find Length\n");
        printf("5. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);
        
        while((ch = getchar()) != '\n');

        switch(choice) {

            case 1:
                printf("Enter string: ");
                fgets(str, sizeof(str), stdin);

                len = strlen(str) - 1; // remove newline

                printf("Reversed string: ");
                for(i = len - 1; i >= 0; i--) {
                    printf("%c", str[i]);
                }
                printf("\n");
                break;

            case 2:
                printf("Enter string: ");
                fgets(str, sizeof(str), stdin);

                for(i = 0; str[i] != '\0'; i++) {
                    if(str[i] >= 'a' && str[i] <= 'z') {
                        str[i] = str[i] - 32;
                    }
                }

                printf("Uppercase string: %s", str);
                break;

            case 3:
                printf("Enter string: ");
                fgets(str, sizeof(str), stdin);

                for(i = 0; str[i] != '\0'; i++) {
                    if(str[i] >= 'A' && str[i] <= 'Z') {
                        str[i] = str[i] + 32;
                    }
                }

                printf("Lowercase string: %s", str);
                break;

            case 4:
                printf("Enter string: ");
                fgets(str, sizeof(str), stdin);

                len = 0;
                for(i = 0; str[i] != '\0'; i++) {
                    if(str[i] != '\n')  // ignore newline
                        len++;
                }

                printf("Length of string = %d\n", len);
                break;

            case 5:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid choice\n");
        }

    } while(choice != 5);

    return 0;
}
